# GradeFlow Environment Variables
# Copy this file to .env.local and fill in your actual values

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google OAuth Configuration
# Note: The Client ID is used for client-side detection only
# Primary OAuth authentication is handled through Supabase
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Development Notes:
# 1. Supabase Setup:
#    - Go to Supabase Dashboard > Authentication > Providers
#    - Enable Google provider
#    - Add your Google Client ID and Client Secret
#    - Set redirect URI to: https://your-domain.vercel.app/auth/callback
#
# 2. Google Cloud Setup:
#    - Create project at https://console.cloud.google.com
#    - Enable Google+ API and Google OAuth2 API
#    - Create OAuth 2.0 Client ID (Web application)
#    - Add redirect URIs:
#      - http://localhost:5173/auth/callback (development)
#      - https://gradeflow-staging.vercel.app/auth/callback (staging)
#      - https://gradeflow-omega.vercel.app/auth/callback (production)
#
# 3. Vercel Environment Variables:
#    - Add the same variables to Vercel dashboard
#    - Set VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY
#    - Set VITE_GOOGLE_CLIENT_ID (optional, for client-side detection)
#
# 4. Security Notes:
#    - Never commit .env.local to version control
#    - Google Client Secret should only be in Supabase, never in frontend
#    - Use different redirect URIs for each environment
#    - Enable HTTPS in production (required for OAuth)
