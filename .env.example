# Supabase Configuration
# Get these values from your Supabase project settings
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# For backend API (Node.js environment)
# These should be set in your hosting environment (Vercel, Netlify, etc.)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Additional configuration
# TESSERACT_WORKER_URL=/node_modules/tesseract.js/dist/worker.min.js

# LLM Proxy Configuration
# Optional: If using LLM-API-Key-Proxy for unified model routing
LLM_PROXY_BASE_URL=
LLM_PROXY_API_KEY=

# Legacy AI Keys (kept for fallback)
# ANTHROPIC_API_KEY=your-anthropic-key-here
